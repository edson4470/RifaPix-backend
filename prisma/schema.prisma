generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model bilhetes {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  rifa_id          String?   @db.Uuid
  comprador_id     String?   @db.Uuid
  numero           Int
  status_pagamento String?   @default("pendente") @db.VarChar(20)
  codigo_pix_txid  String?   @db.VarChar(255)
  criado_em        DateTime? @default(now()) @db.Timestamptz(6)
  atualizado_em    DateTime? @default(now()) @db.Timestamptz(6)
  usuarios         usuarios? @relation(fields: [comprador_id], references: [id], onUpdate: NoAction)
  rifas            rifas?    @relation(fields: [rifa_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([rifa_id, numero])
  @@index([rifa_id, status_pagamento], map: "idx_bilhetes_rifa_status")
  @@index([codigo_pix_txid], map: "idx_bilhetes_txid")
}

model rifas {
  id                 String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  criador_id         String?    @db.Uuid
  titulo             String     @db.VarChar(150)
  descricao          String?
  preco_bilhete      Decimal    @db.Decimal(10, 2)
  quantidade_numeros Int
  // Campo novo para as imagens
  imagens            String[]   @default([])
  status             String?    @default("ativa") @db.VarChar(20)
  data_sorteio       DateTime?  @db.Timestamptz(6)
  numero_sorteado    Int?
  criado_em          DateTime?  @default(now()) @db.Timestamptz(6)
  atualizado_em      DateTime?  @default(now()) @db.Timestamptz(6)
  bilhetes           bilhetes[]
  usuarios           usuarios?  @relation(fields: [criador_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status], map: "idx_rifas_status")
}

model usuarios {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nome          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(150)
  telefone      String    @db.VarChar(20)
  senha_hash    String    @db.VarChar(255)
  criado_em     DateTime? @default(now()) @db.Timestamptz(6)
  atualizado_em DateTime? @default(now()) @db.Timestamptz(6)
  bilhetes      bilhetes[]
  rifas         rifas[]
}